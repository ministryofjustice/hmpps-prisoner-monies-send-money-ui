{% extends "../partials/layout.njk" %}

{% set pageTitle = applicationName + "Send Money to Prisoner - Home" %}
{% set mainClasses = "govuk-body" %}

{% block content %}

  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <div class="gem-c-title govuk-!-margin-top-0 govuk-!-margin-bottom-8">

        <h1 class="gem-c-title__text govuk-heading-xl">
          Send money to someone in prison
        </h1>
      </div>
    </div>
    <div class="article-container group govuk-grid-column-two-thirds">
      <div class="content-block">
        <div class="inner">
          <section class="intro">
            <p id="get-started" class="get-started group">

              <a class="gem-c-button govuk-button govuk-button--start gem-c-button--bottom-margin" role="button" rel="external" draggable="false" href="{{ sendMoneyUrl }}">
                <span>Start now</span>
                <svg class="govuk-button__start-icon govuk-!-display-none-print" xmlns="http://www.w3.org/2000/svg"
                     width="17.5" height="19" viewBox="0 0 33 40" focusable="false" aria-hidden="true">
                  <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"></path>
                </svg>
              </a>
            </p>
          </section>
        </div>
      </div>
    </div>

    <div class="govuk-grid-column-one-third">
      <div class="gem-c-contextual-sidebar">
        <div class="gem-c-related-navigation">
          <h2 id="related-nav-related_items-3f1fd884" class="gem-c-related-navigation__main-heading">
            Related content
          </h2>

          <nav role="navigation" class="gem-c-related-navigation__nav-section" aria-labelledby="related-nav-related_items-3f1fd884">

            <ul class="gem-c-related-navigation__link-list">
              <li class="gem-c-related-navigation__link"><a
                class="govuk-link govuk-link gem-c-related-navigation__section-link govuk-link gem-c-related-navigation__section-link--sidebar  govuk-link gem-c-related-navigation__section-link--other"
                href="/info-page">Staying in touch with someone in prison</a></li>
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
